{
  "description": "RPC integration tests run on every supported Unity editor line.",
  "entries": [
    {
      "id": "hierarchy_create_object",
      "method": "unity.create_object",
      "params": { "name": "__mcp_test_object" },
      "expect": { "hasKeys": ["id"] },
      "cleanup": "destroyById"
    },
    {
      "id": "project_get_info",
      "method": "unity.get_project_info",
      "params": {},
      "expect": { "hasKeys": ["productName", "unityVersion"] }
    },
    {
      "id": "smoke_create_sphere",
      "method": "unity.create_primitive",
      "params": { "type": "Sphere", "name": "__mcp_smoke_sphere" },
      "expect": { "hasKeys": ["id"] },
      "cleanup": "destroyById",
      "tags": ["smoke"]
    }
  ]
}
